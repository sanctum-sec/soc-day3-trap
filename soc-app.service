[Unit]
Description=SOC Trap Ingest API (wic01) — port 8000
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/app
ExecStart=/home/ubuntu/app/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
StandardOutput=append:/home/ubuntu/app/logs/ops.log
StandardError=append:/home/ubuntu/app/logs/ops.log

[Install]
WantedBy=multi-user.target
