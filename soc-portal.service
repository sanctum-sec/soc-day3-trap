[Unit]
Description=SOC Day3 Portal Honeypot (wic01) — port 80
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/app
ExecStart=/home/ubuntu/app/venv/bin/uvicorn portal:app --host 0.0.0.0 --port 80
Restart=always
RestartSec=5
AmbientCapabilities=CAP_NET_BIND_SERVICE
StandardOutput=append:/home/ubuntu/app/logs/ops.log
StandardError=append:/home/ubuntu/app/logs/ops.log

[Install]
WantedBy=multi-user.target
